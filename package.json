{
  "name": "chromacode",
  "version": "0.1.0",
  "description": "Multi-dimensional visual data encoding using color + opacity channels",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "PROTOCOL.md",
    "LICENSE",
    "README.md"
  ],
  "gypfile": true,
  "scripts": {
    "build": "tsup",
    "build:native": "node-gyp configure build",
    "build:native:c": "cd native && make all",
    "test": "vitest run",
    "test:native": "cd native && make test",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ tests/",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts'"
  },
  "keywords": [
    "encoding",
    "visual",
    "data",
    "png",
    "chromacode",
    "reed-solomon",
    "error-correction"
  ],
  "author": "Adam Irwin White",
  "repository": {
    "type": "git",
    "url": "https://github.com/1adam12vibecoder-create/chromacode.git"
  },
  "homepage": "https://github.com/1adam12vibecoder-create/chromacode",
  "bugs": {
    "url": "https://github.com/1adam12vibecoder-create/chromacode/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.3",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^2.0.0"
  }
}
